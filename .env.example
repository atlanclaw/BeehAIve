# ══════════════════════════════════════════════════════════════════════════════
# BeehAIve PKB — .env.example
# BASE-Architektur: LH → L0 → L1 → L2
#
# Port-Symbolik:
#   :777  → Host :7777  (pkb-gateway  L6 Engels-Tor)
#   :369  → Host :3693  (l3-dispatcher L3) / :3692 (pkb-ingestion L2)
#   :471  → Host :4713  (pkb-beeai    L3)
#   :108  → Host :1081  (qdrant       L1) / :1084 (langfuse L4)
#            Container-Ports: qdrant:1337 / langfuse:7777
# ══════════════════════════════════════════════════════════════════════════════

# ── L6 Gateway ───────────────────────────────────────────────────────────────
GATEWAY_PORT=7777
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ALLOWED_IDS=123456789,987654321
mem_hard_gateway_L6=128m
mem_soft_gateway_L6=64m
cpu_hard_gateway_L6=0.1

# ── L6 Auditor ───────────────────────────────────────────────────────────────
mem_hard_auditor_L6=64m
mem_soft_auditor_L6=32m
cpu_hard_auditor_L6=0.05

# ── L3 Dispatcher ────────────────────────────────────────────────────────────
DISPATCHER_PORT=3693
BEEAI_ENDPOINT=http://pkb-beeai:4713
mem_hard_dispatcher_L3=128m
mem_soft_dispatcher_L3=64m
cpu_hard_dispatcher_L3=0.1

# ── L3 BeeAI ─────────────────────────────────────────────────────────────────
BEEAI_PORT=4713
BEE_LLM=qwen2.5:3b
BEE_MEMORY_TYPE=UnconstrainedMemory
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
mem_hard_beeai_L3=128m
mem_soft_beeai_L3=64m
cpu_hard_beeai_L3=0.1

# ── L2 Ingestion ─────────────────────────────────────────────────────────────
INGESTION_PORT=3692
mem_hard_ingestion_L2=256m
mem_soft_ingestion_L2=64m
cpu_hard_ingestion_L2=0.2

# ── L2-05 TOON ───────────────────────────────────────────────────────────────
TOON_URL=http://pkb-toon:8080
TOON_TIMEOUT_S=5.0
TOON_DEFAULT_MODEL=llama3.1:8b
TOON_DEFAULT_MODEL_NAME=Llama 3.1 8B (lokal)

# ── L2-06 ModelSelector ──────────────────────────────────────────────────────
AVAILABLE_MODELS=llama3.1:8b,qwen2.5:32b
DEFAULT_MODEL=llama3.1:8b
DEFAULT_MODEL_NAME=Llama 3.1 8B (lokal)

# ── L2-07 OTEL ───────────────────────────────────────────────────────────────
OTEL_SAMPLE_RATE=1.0
SERVICE_VERSION=0.1.0
TOON_HEALTH_TIMEOUT_S=2.0

# ── L1 Qdrant ────────────────────────────────────────────────────────────────
# Host-Port :1081 → Container-Port :1337
QDRANT_PORT=1081
QDRANT_CONTAINER_PORT=1337
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://qdrant:1337

# ── L1 Qdrant Collections ────────────────────────────────────────────────────
EMBEDDING_DIM=768
QDRANT_HNSW_M=16
QDRANT_HNSW_EF_CONSTRUCT=100

# ── L4 Langfuse ──────────────────────────────────────────────────────────────
# Host-Port :1084 → Container-Port :7777
LANGFUSE_PORT=1084
LANGFUSE_CONTAINER_PORT=7777
LANGFUSE_HOST=http://langfuse-web:7777
OTEL_EXPORTER_OTLP_ENDPOINT=http://langfuse-web:4318
LANGFUSE_SALT=change-me-random-salt-32chars
NEXTAUTH_SECRET=change-me-random-secret-32chars
NEXTAUTH_URL=http://localhost:1084
DATABASE_URL=postgresql://langfuse:langfuse@langfuse-postgres:5432/langfuse

# ── L0 Resource Manager ──────────────────────────────────────────────────────
mem_soft_resmanager_L0=64m
mem_hard_resmanager_L0=256m
RESOURCE_BUDGETS_CONFIG=/app/config/resource-budgets.yaml

# ── PKB Paths ─────────────────────────────────────────────────────────────────
PKB_ROOT=/srv/pkb
PIPELINE_STAGES_CONFIG=/app/config/pipeline-stages.yaml
