FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.beeai.txt .
RUN pip install --no-cache-dir -r requirements.beeai.txt

COPY beeai/ ./beeai/

EXPOSE 4713

HEALTHCHECK --interval=30s --timeout=10s --retries=5 \
  CMD curl -f http://localhost:4713/health || exit 1

CMD ["uvicorn", "beeai.main:app", "--host", "0.0.0.0", "--port", "4713"]
